---
import BaseLayout from '../layouts/BaseLayout.astro';
import { nowItems, workItems } from '../data/site';
---

<BaseLayout
  title="Now - Jay Lee"
  description="What Jay Lee is building and thinking about now: AI memory, transcript workflows, voice-to-note systems, and public-safe archive work."
>
  <section class="section page-hero">
    <div class="section-header compact-header">
      <h1>Now</h1>
      <p>A short, public-safe log of current focus. Tools and ideas only, not private conversations or private records.</p>
    </div>

    <div class="now-grid">
      <section aria-labelledby="building-title">
        <h2 id="building-title">Building</h2>
        <ul class="focus-list">
          {nowItems.map((item) => <li>{item}</li>)}
        </ul>
      </section>

      <section aria-labelledby="reading-title">
        <h2 id="reading-title">Reading for</h2>
        <p>
          Practical patterns: how people keep context, check AI outputs, turn rough inputs into useful notes, and decide what
          should never leave the private workspace.
        </p>
      </section>
    </div>
  </section>

  <section class="section compact-section" aria-labelledby="open-loops-title">
    <div class="section-header compact-header">
      <h2 id="open-loops-title">Connected pieces</h2>
      <p>
        If a current focus becomes public, it should land as a small artifact: a repo, a note, or a clear example.
      </p>
    </div>
    <div class="archive-timeline quiet-timeline">
      {
        workItems.slice(0, 3).map((item) => (
          <a class:list={['archive-item', item.featured && 'featured']} href={item.href}>
            <span class="archive-dot" aria-hidden="true"></span>
            <span class="archive-meta">
              <span>{item.kind}</span>
              <time datetime={item.dateTime}>{item.date}</time>
            </span>
            <strong>{item.title}</strong>
            <p>{item.summary}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section compact-section about-panel" aria-labelledby="now-boundary-title">
    <h2 id="now-boundary-title">Intentionally absent</h2>
    <p>
      No family, health, employer, finance, account, or private conversation details. The public version keeps the pattern
      and removes the private room.
    </p>
  </section>
</BaseLayout>
