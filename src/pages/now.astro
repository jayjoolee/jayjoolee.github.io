---
import ArchiveTimeline from '../components/ArchiveTimeline.astro';
import { latestTrailBase, nowGroups } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildArchiveTrail, getWritingItems } from '../lib/writing';

const writingItems = await getWritingItems();
const latestTrail = buildArchiveTrail(latestTrailBase, writingItems, 4);
---

<BaseLayout
  title="Now - Jay Lee"
  description="What Jay Lee is building, learning, and practicing in July 2026."
>
  <section class="section page-hero">
    <div class="section-header compact-header">
      <h1>Now · July 2026</h1>
      <p>A dated snapshot of what has my attention. It can change without becoming a permanent biography.</p>
    </div>

    <div class="now-grid">
      {
        nowGroups.map((group) => (
          <section aria-labelledby={`now-${group.title.toLowerCase()}`}>
            <h2 id={`now-${group.title.toLowerCase()}`}>{group.title}</h2>
            <ul class="focus-list">
              {group.items.map((item) => <li>{item}</li>)}
            </ul>
          </section>
        ))
      }
    </div>
  </section>

  <section class="section compact-section" aria-labelledby="now-trail-title">
    <div class="section-header compact-header">
      <h2 id="now-trail-title">What this is becoming</h2>
      <p>The current interests should leave a trail in code, notes, or study entries, not just stay as a list of claims.</p>
    </div>
    <ArchiveTimeline items={latestTrail} quiet label="Current archive trail" />
  </section>
</BaseLayout>
