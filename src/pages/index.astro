---
import BaseLayout from '../layouts/BaseLayout.astro';
import { noteLinks, nowItems, openSourceItems, workItems } from '../data/site';
---

<BaseLayout
  title="Jay Lee - AI Memory and Work Archive"
  description="A compact archive of public-safe notes on AI memory, transcripts, work systems, and human judgment."
>
  <section class="hero">
    <p class="lead">
      I am interested in AI memory that helps people think better: turning transcripts, notes, and everyday context into
      insights they can inspect, question, and use.
    </p>
  </section>

  <section class="section" aria-labelledby="work-title">
    <div class="section-header compact-header">
      <h1 id="work-title">Work</h1>
      <p>
        The first object here is the memory contract: AI should not imitate a person. It should help the person notice,
        compare, and decide better.
      </p>
    </div>
    <div class="archive-timeline">
      {
        workItems.map((item) => (
          <a class:list={['archive-item', item.featured && 'featured']} href={item.href}>
            <span class="archive-dot" aria-hidden="true"></span>
            <span class="archive-meta">
              <span>{item.kind}</span>
              <time datetime={item.dateTime}>{item.date}</time>
            </span>
            <strong>{item.title}</strong>
            <p>{item.summary}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section compact-section" aria-labelledby="tools-title">
    <div class="section-header compact-header">
      <h2 id="tools-title">Small Tools</h2>
      <p>Open-source utilities from the same workbench. Small, local-first, and inspectable.</p>
    </div>
    <div class="archive-timeline quiet-timeline">
      {
        openSourceItems.map((item) => (
          <a class:list={['archive-item', item.featured && 'featured']} href={item.href}>
            <span class="archive-dot" aria-hidden="true"></span>
            <span class="archive-meta">
              <span>{item.kind}</span>
              <time datetime={item.dateTime}>{item.date}</time>
            </span>
            <strong>{item.title}</strong>
            <p>{item.summary}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section compact-section" aria-labelledby="notes-title">
    <div class="section-header compact-header">
      <h2 id="notes-title">Notes</h2>
      <p>Short field notes tied to the public work. No private transcripts, employer material, or personal records.</p>
    </div>
    <div class="archive-timeline quiet-timeline">
      {
        noteLinks.map((note) => (
          <a class:list={['archive-item', note.featured && 'featured']} href={note.href}>
            <span class="archive-dot" aria-hidden="true"></span>
            <span class="archive-meta">
              <span>{note.label}</span>
              <time datetime={note.dateTime}>{note.date}</time>
            </span>
            <strong>{note.title}</strong>
            <p>{note.summary}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section" aria-labelledby="now-title">
    <div class="plain-panel">
      <h2 id="now-title">Now</h2>
      <ul>
        {nowItems.slice(0, 3).map((item) => <li>{item}</li>)}
      </ul>
      <a class="standalone-link" href="/now/">Open Now</a>
    </div>
  </section>

  <section class="section language-band" lang="ko">
    <h2>한국어 요약</h2>
    <p>
      이 사이트는 AI가 사람을 흉내 내는 방향이 아니라, 사람이 더 잘 판단하도록 돕는 기억과 작업 시스템을 다루는
      개인 아카이브입니다.
    </p>
    <a class="standalone-link" href="/ko/">한국어 요약 보기</a>
  </section>
</BaseLayout>
