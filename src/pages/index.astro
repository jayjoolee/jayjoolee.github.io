---
import ArchiveTimeline from '../components/ArchiveTimeline.astro';
import GardenIndex from '../components/GardenIndex.astro';
import { gardenPaths, latestTrailBase, nowGroups } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildArchiveTrail, getWritingItems, withWritingCount } from '../lib/writing';

const writingItems = await getWritingItems();
const latestTrail = buildArchiveTrail(latestTrailBase, writingItems, 7);
const archivePaths = withWritingCount(gardenPaths, `${writingItems.length} notes`);
---

<BaseLayout
  title="Jay Lee - Personal Archive"
  description="Jay Lee's living archive of work, GitHub activity, notes, reading, places, career, and current interests."
>
  <section class="hero">
    <p class="lead">
      I’m Jay, an HRD practitioner and builder. This is a living archive of what I make, read, learn, and notice—mostly
      around AI, work, and the systems underneath both.
    </p>
  </section>

  <section class="section" aria-labelledby="trail-title">
    <div class="section-header compact-header">
      <h1 id="trail-title">Latest Trail</h1>
      <p>Recent code, notes, and learning in one chronology. The labels change because the person behind the work does too.</p>
    </div>
    <ArchiveTimeline items={latestTrail} label="Latest archive trail" />
  </section>

  <section class="section compact-section" aria-labelledby="garden-title">
    <div class="section-header compact-header">
      <h2 id="garden-title">Garden</h2>
      <p>Four ways into the archive, from public notes to the books and places that changed a question.</p>
    </div>
    <GardenIndex paths={archivePaths} />
    <a class="standalone-link" href="/garden/">Open the Garden</a>
  </section>

  <section class="section" aria-labelledby="now-title">
    <div class="plain-panel">
      <h2 id="now-title">Now · July 2026</h2>
      <ul>
        {nowGroups[0].items.map((item) => <li>{item}</li>)}
      </ul>
      <a class="standalone-link" href="/now/">Open Now</a>
    </div>
  </section>

  <section class="section language-band" lang="ko">
    <h2>한국어 요약</h2>
    <p>작업만 보여주는 포트폴리오가 아니라, 무엇을 만들고 읽고 배우고 궁금해하는지 함께 쌓아가는 개인 아카이브입니다.</p>
    <a class="standalone-link" href="/ko/">한국어 요약 보기</a>
  </section>
</BaseLayout>
