---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { noteLinks } from '../../data/site';
---

<BaseLayout
  title="Notes - Jay Lee"
  description="Short public-safe notes from Jay Lee's personal archive: memory, audio workflows, and AI experiments."
>
  <section class="section page-hero">
    <div class="section-header compact-header">
      <h1>Notes</h1>
      <p>Short public notes. They explain the operating ideas behind the archive without exposing the underlying private room.</p>
    </div>
    <h2 class="sr-only">Note list</h2>
    <div class="archive-timeline">
      {
        noteLinks.map((note) => (
          <a class:list={['archive-item', note.featured && 'featured']} href={note.href}>
            <span class="archive-dot" aria-hidden="true"></span>
            <span class="archive-meta">
              <span>{note.label}</span>
              <time datetime={note.dateTime}>{note.date}</time>
            </span>
            <strong>{note.title}</strong>
            <p>{note.summary}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
