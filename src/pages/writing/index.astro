---
import ArchiveTimeline from '../../components/ArchiveTimeline.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getWritingItems } from '../../lib/writing';

const writingItems = await getWritingItems();
---

<BaseLayout
  title="Notes - Jay Lee"
  description="Field notes from Jay Lee's garden on memory, audio workflows, evaluation, and human review."
>
  <section class="section page-hero">
    <div class="section-header compact-header">
      <h1>Notes</h1>
      <p>Published field notes behind the tools. Short enough to revisit, specific enough to change how I build.</p>
    </div>
    <h2 class="sr-only">Note list</h2>
    <ArchiveTimeline items={writingItems} label="Published notes" />
  </section>

  <section class="section compact-section language-band">
    <p>The wider garden also includes what I am <a href="/library/">reading and learning</a> and the <a href="/places/">places</a> I can share.</p>
  </section>
</BaseLayout>
