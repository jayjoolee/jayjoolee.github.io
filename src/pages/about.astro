---
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutFacts } from '../data/site';
---

<BaseLayout
  title="About - Jay Lee"
  description="About Jay Lee's public-safe archive of AI memory, notes, transcripts, and work systems."
>
  <section class="section page-hero">
    <div class="section-header compact-header">
      <h1>About</h1>
      <p>
        I work on the ordinary layer where AI meets real work: what gets remembered, what gets checked, what should stay
        private, and how a messy transcript or note becomes something a person can inspect.
      </p>
    </div>
    <h2 class="sr-only">About facts</h2>
    <div class="archive-timeline quiet-timeline">
      {
        aboutFacts.map((fact) => (
          <article class="archive-item">
            <span class="archive-dot" aria-hidden="true"></span>
            <span class="archive-meta"><span>About</span></span>
            <strong>{fact.title}</strong>
            <p>{fact.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section compact-section about-panel" aria-labelledby="boundary-title">
    <h2 id="boundary-title">Public boundary</h2>
    <p>
      This site can show methods, synthetic examples, public repositories, and the shape of my thinking. It does not publish
      private conversations, employer material, family or health details, financial account material, or unapproved identity
      traces.
    </p>
  </section>

  <section class="section contact-section" aria-labelledby="contact-title">
    <h2 id="contact-title">Links</h2>
    <div class="contact-links">
      <a class="standalone-link" href="https://github.com/jayjoolee">GitHub</a>
      <a class="standalone-link" href="https://www.linkedin.com/in/jay-joowon-lee-0334501a8/">LinkedIn</a>
      <a class="standalone-link" href="/projects/">Archive</a>
    </div>
  </section>
</BaseLayout>
