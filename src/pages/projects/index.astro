---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { openSourceItems, workItems } from '../../data/site';
---

<BaseLayout
  title="Work - Jay Lee"
  description="Public-safe AI memory, transcript, workflow, and prototype artifacts from Jay Lee."
>
  <section class="section page-hero">
    <div class="section-header compact-header">
      <h1>Work</h1>
      <p>
        Public artifacts and working directions. The list is intentionally small: memory, transcripts, workflow audits, and
        loops for making AI work inspectable.
      </p>
    </div>
    <h2 class="sr-only">Work list</h2>
    <div class="archive-timeline">
      {
        workItems.map((item) => (
          <a class:list={['archive-item', item.featured && 'featured']} href={item.href}>
            <span class="archive-dot" aria-hidden="true"></span>
            <span class="archive-meta">
              <span>{item.kind}</span>
              <time datetime={item.dateTime}>{item.date}</time>
            </span>
            <strong>{item.title}</strong>
            <p>{item.summary}</p>
          </a>
        ))
      }
    </div>
  </section>
  <section class="section compact-section" aria-labelledby="tools-title">
    <div class="section-header compact-header">
      <h2 id="tools-title">Small Tools</h2>
      <p>Open-source utilities that keep the archive connected to shipped code, not just notes.</p>
    </div>
    <div class="archive-timeline quiet-timeline">
      {
        openSourceItems.map((item) => (
          <a class:list={['archive-item', item.featured && 'featured']} href={item.href}>
            <span class="archive-dot" aria-hidden="true"></span>
            <span class="archive-meta">
              <span>{item.kind}</span>
              <time datetime={item.dateTime}>{item.date}</time>
            </span>
            <strong>{item.title}</strong>
            <p>{item.summary}</p>
          </a>
        ))
      }
    </div>
  </section>
  <section class="section compact-section">
    <div class="section-header compact-header">
      <h2>Inspection order</h2>
      <p>
        Start with the memory contract if you want the site thesis. Open the workflow kit if you want runnable public proof.
      </p>
    </div>
    <p class="plain-copy">
      This archive avoids private transcripts, employer context, account data, family or health detail, and unapproved
      identity traces. Public examples stay synthetic or method-level.
    </p>
  </section>
</BaseLayout>
