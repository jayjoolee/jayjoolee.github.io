---
import ArchiveTimeline from '../../components/ArchiveTimeline.astro';
import { githubUpdates, publicWork } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Work - Jay Lee"
  description="Public repositories, small tools, and recent GitHub updates from Jay Lee."
>
  <section class="section page-hero">
    <div class="section-header compact-header">
      <h1>Work</h1>
      <p>
        Small public tools for learning, memory, and inspectable AI work. The repository is the artifact; the commit trail
        shows how it changed.
      </p>
    </div>
    <h2 class="sr-only">Public work</h2>
    <ArchiveTimeline items={publicWork} label="Public work" />
  </section>

  <section class="section compact-section" aria-labelledby="github-title">
    <div class="section-header compact-header">
      <h2 id="github-title">Recent GitHub Updates</h2>
      <p>Selected public commits, linked to the exact change rather than summarized as a generic contribution count.</p>
    </div>
    <ArchiveTimeline items={githubUpdates} quiet label="Recent GitHub updates" />
  </section>

  <section class="section compact-section about-panel" aria-labelledby="work-context-title">
    <h2 id="work-context-title">The work around the code</h2>
    <p>
      My day-to-day background is HRD and AI education. The public repositories are where those questions become small,
      inspectable experiments. <a href="/career/">See the career timeline.</a>
    </p>
  </section>
</BaseLayout>
