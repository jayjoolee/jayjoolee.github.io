---
import '../styles/global.css';

type NavItem = {
  readonly href: string;
  readonly label: string;
  readonly matches: readonly string[];
  readonly lang?: string;
  readonly rel?: string;
};

const {
  title = 'Jay Lee - Personal Archive',
  description = "Jay Lee's living archive of work, notes, reading, places, career, and current interests.",
  locale = 'en',
} = Astro.props;

const site = 'https://jayjoolee.github.io';
const canonical = new URL(Astro.url.pathname, site).toString();
const socialImage = new URL('/assets/social-card.svg', site).toString();
const isKorean = locale === 'ko';
const currentPath = Astro.url.pathname;
const siteName = 'Jay Lee';
const themeColor = '#f5f4ef';
const hasLocalizedAlternate = currentPath === '/' || currentPath === '/ko/';
const navItems = [
  {
    href: isKorean ? '/ko/' : '/',
    label: isKorean ? '홈' : 'Home',
    matches: [isKorean ? '/ko/' : '/'],
  },
  {
    href: '/garden/',
    label: isKorean ? '가든' : 'Garden',
    matches: ['/garden/', '/writing/', '/library/', '/places/'],
  },
  { href: '/projects/', label: isKorean ? '작업' : 'Work', matches: ['/projects/'] },
  { href: '/now/', label: 'Now', matches: ['/now/'] },
  {
    href: '/about/',
    label: isKorean ? '소개' : 'About',
    matches: ['/about/', '/career/'],
  },
  {
    href: isKorean ? '/' : '/ko/',
    label: isKorean ? 'English' : '한국어',
    matches: [],
    lang: isKorean ? 'en' : 'ko',
  },
  {
    href: 'https://github.com/jayjoolee',
    label: 'GitHub',
    matches: [],
    rel: 'me',
  },
] satisfies readonly NavItem[];
const isActive = (item: NavItem) =>
  item.matches.some((match) => (match === '/' ? currentPath === '/' : currentPath.startsWith(match)));
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: siteName,
  url: site,
  sameAs: ['https://github.com/jayjoolee', 'https://www.linkedin.com/in/jay-joowon-lee-0334501a8/'],
  knowsAbout: [
    'Human resource development',
    'AI education',
    'Small AI tools',
    'Workflow evaluation',
    'Personal knowledge systems',
    'Workplace learning',
  ],
};
---

<!doctype html>
<html lang={isKorean ? 'ko' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Jay Lee" />
    <meta name="theme-color" content={themeColor} />
    <link rel="canonical" href={canonical} />
    {
      hasLocalizedAlternate && (
        <>
          <link rel="alternate" hreflang="en" href={new URL('/', site).toString()} />
          <link rel="alternate" hreflang="ko" href={new URL('/ko/', site).toString()} />
          <link rel="alternate" hreflang="x-default" href={new URL('/', site).toString()} />
        </>
      )
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content="Jay Lee personal archive preview" />
    <meta property="og:site_name" content="Jay Lee - Personal Archive" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="generator" content={Astro.generator} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">{isKorean ? '본문으로 이동' : 'Skip to content'}</a>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href={isKorean ? '/ko/' : '/'}>{siteName}</a>
        <nav class="nav" aria-label={isKorean ? '주요 내비게이션' : 'Main navigation'}>
          {
            navItems.map((item) => (
              <a
                href={item.href}
                aria-current={isActive(item) ? 'page' : undefined}
                lang={item.lang}
                rel={item.rel}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <span>
        {isKorean
          ? '작업, 배움, 장소, 커리어와 요즘의 질문을 함께 쌓는 개인 아카이브입니다.'
          : 'A living archive of work, learning, places, career, and changing questions.'}
      </span>
      <span>
        <a href="/garden/">{isKorean ? '가든' : 'Garden'}</a>
        <a href="/projects/">{isKorean ? '작업' : 'Work'}</a>
        <a href="/now/">Now</a>
        <a href="/about/">{isKorean ? '소개' : 'About'}</a>
        <a href="https://github.com/jayjoolee/jayjoolee.github.io">Source</a>
      </span>
    </footer>
  </body>
</html>
